{
  "installCommand": "pnpm install",
  "buildCommand": "cd src/admin && pnpm install && npx vite build",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/takoio" }
  ],
  "functions": {
    "api/takoio.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
