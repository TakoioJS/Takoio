{
  "installCommand": "npm install -g pnpm@9 && pnpm install",
  "buildCommand": "cd src/server/self-hosted && npx tsc",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/takoio" }
  ],
  "functions": {
    "api/takoio.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
