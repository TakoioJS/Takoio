{
  "installCommand": "pnpm install",
  "buildCommand": "",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/takoio" }
  ],
  "functions": {
    "api/takoio.ts": {
      "memory": 256,
      "maxDuration": 30,
      "includeFiles": "src/server/self-hosted/**/*.ts"
    }
  }
}
