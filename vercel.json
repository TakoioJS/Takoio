{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build:admin && cd src/server/self-hosted && pnpm build",
  "framework": null,
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/takoio" }
  ],
  "functions": {
    "api/takoio.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
