{
  "name": "takoio-server",
  "version": "1.0.0",
  "description": "Takoio server (Nitro + Drizzle ORM)",
  "main": ".output/server/index.mjs",
  "type": "module",
  "scripts": {
    "dev": "nitro dev",
    "prepare": "nitro prepare",
    "build": "nitro build && node scripts/copy-xdb.mjs .output/server",
    "build:vercel": "NITRO_PRESET=vercel nitro build && node scripts/copy-xdb.mjs .vercel/output/functions/__server.func",
    "build:netlify": "NITRO_PRESET=netlify nitro build && node scripts/copy-xdb.mjs .output/server",
    "start": "PORT=8080 node .output/server/index.mjs",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:import": "tsx scripts/import-from-json.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@takoio/common": "workspace:*",
    "@libsql/client": "^0.17.4",
    "ai": "^7.0.2",
    "drizzle-orm": "^0.45.2",
    "h3": "2.0.1-rc.22",
    "ioredis": "^5.11.1",
    "ip2region-ts": "^2.0.1",
    "mongodb": "^7.3.0",
    "nitro": "3.0.260610-beta",
    "nodemailer": "^9.0.1",
    "postgres": "^3.4.9",
    "pushoo": "^0.1.12",
    "shiki": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^8.0.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}