{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@shared/*": ["../client/*"],
      "@takoio/common": ["../../src/shared/common"],
      "@takoio/core": ["../../src/shared/core"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.vue",
    "../client/utils/**/*.ts",
    "../client/types.ts",
    "../client/version.ts"
  ]
}
