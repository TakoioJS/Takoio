{
  "name": "takoio",
  "version": "1.3.2",
  "description": "A simple, free comment system with Vue 3 + Vite 8",
  "keywords": [
    "takoio",
    "comment",
    "comment-system"
  ],
  "author": "Takoio Contributors",
  "contributors": [
    "PaloMiku <palomiku@outlook.com> (https://github.com/PaloMiku)"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/"
  ],
  "main": "./dist/takoio.cjs",
  "module": "./dist/takoio.esm.js",
  "types": "./dist/takoio.esm.d.ts",
  "unpkg": "./dist/takoio.esm.js",
  "jsdelivr": "./dist/takoio.esm.js",
  "exports": {
    ".": {
      "types": "./dist/takoio.esm.d.ts",
      "import": "./dist/takoio.esm.js",
      "require": "./dist/takoio.cjs",
      "default": "./dist/takoio.esm.js"
    },
    "./dist/takoio.min.css": "./dist/takoio.min.css",
    "./dist/takoio.min.js": "./dist/takoio.min.js",
    "./dist/takoio.esm.js": "./dist/takoio.esm.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TakoioJS/Takoio.git"
  },
  "scripts": {
    "dev": "node dev.mjs",
    "dev:client": "vite --host 127.0.0.1 --port 9820",
    "dev:server": "pnpm --filter takoio-server dev",
    "dev:admin": "pnpm --filter takoio-admin dev",
    "build": "pnpm build:esm && pnpm build:umd",
    "build:esm": "vite build --mode esm",
    "build:umd": "pnpm vite build --mode umd",
    "build:admin": "pnpm --filter takoio-admin build",
    "build:server": "pnpm --filter takoio-server build",
    "build:serverless": "pnpm build:server && pnpm build:admin",
    "build:all": "pnpm build && pnpm build:admin",
    "build:analyze": "ANALYZE=true vite build --mode umd",
    "build:check-size": "node scripts/size-check.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 9820",
    "lint": "eslint src/**/*.{ts,vue}",
    "lint:fix": "eslint src/**/*.{ts,vue} --fix",
    "lint:arch": "eslint --config eslint.config.js src/server/core src/server/nitro",
    "type-check": "vue-tsc --noEmit && pnpm --filter takoio-server type-check",
    "type-check:all": "vue-tsc --noEmit && pnpm --filter takoio-admin type-check && pnpm --filter takoio-server type-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "shiki": "^4.3.0"
  },
  "devDependencies": {
    "@iconify-json/jam": "^1.2.3",
    "@iconify-json/lucide": "^1.2.115",
    "@iconify-json/simple-icons": "^1.2.88",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/test-utils": "^2.4.11",
    "@vueuse/core": "14.3.0",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "neostandard": "^0.13.0",
    "pinia": "^3.0.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "sql.js": "^1.14.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.4",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "vue-eslint-parser": "^10.4.1",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.5"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.0.0"
  }
}
