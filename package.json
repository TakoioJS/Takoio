{
  "name": "takoio",
  "version": "1.0.0",
  "description": "A simple, free comment system with Vue 3 + Element Plus.",
  "keywords": [
    "takoio",
    "comment",
    "comment-system"
  ],
  "author": "Takoio Contributors",
  "contributors": [
    "iMaeGoo <hello@imaegoo.com> (https://github.com/imaegoo)"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/takoio.min.js",
  "module": "./dist/takoio.esm.js",
  "exports": {
    ".": {
      "import": "./dist/takoio.esm.js",
      "require": "./dist/takoio.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/takoio/takoio.git"
  },
  "homepage": "https://takoio.js.org",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 9820",
    "build": "pnpm build:esm && pnpm build:umd",
    "build:esm": "vite build --mode esm",
    "build:umd": "node build-umd.js",
    "build:server": "cd src/server/self-hosted && pnpm install && npx tsc",
    "build:analyze": "node -e \"process.env.ANALYZE='true';import('./build-umd.js')\"",
    "preview": "vite preview --host 0.0.0.0 --port 9820",
    "lint": "eslint src/**/*.{ts,vue}",
    "lint:fix": "eslint src/**/*.{ts,vue} --fix",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:dev": "cd docs && yarn docs:dev",
    "docs:build": "cd docs && yarn docs:build"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@iconify/vue": "^5.0.1",
    "blueimp-md5": "^2.19.0",
    "dompurify": "^3.4.11",
    "element-plus": "^2.14.2",
    "hono": "^4.12.26",
    "katex": "^0.17.0",
    "lucide-vue-next": "^0.460.0",
    "marked": "^18.0.0",
    "shiki": "^1.24.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/blueimp-md5": "^2.18.2",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^29.1.1",
    "neostandard": "^0.13.0",
    "rollup": "^4.62.2",
    "rollup-plugin-visualizer": "^7.0.0",
    "sass": "^1.101.0",
    "typescript": "^5.7.2",
    "unocss": "^66.7.2",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^3.1.0",
    "vue-tsc": "^2.1.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
