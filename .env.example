# ===========================================
# Takoio 云函数部署环境变量模板
# ===========================================
# 复制此文件为 .env 或直接在部署平台设置环境变量
# cp .env.example .env

# ---- 数据库类型 (必填) ----
# 本地/自托管: sqlite (默认)
# Vercel / Netlify 云函数: mongodb (推荐)
DB_TYPE=mongodb

# ---- MongoDB 连接串 (DB_TYPE=mongodb 时必填) ----
# 推荐使用 MongoDB Atlas 免费版: https://www.mongodb.com/atlas
# 格式: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/takoio
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/takoio

# ---- MongoDB 数据库名 (可选) ----
# 默认为 takoio
# MONGODB_DB=takoio

# ---- API 限流 (可选) ----
# 同一 IP 请求间隔（毫秒），默认 250
TAKOIO_THROTTLE=250

# ---- 首次设置令牌 (推荐) ----
# 设置后，首次创建管理员密码时需提供此令牌，防止未授权抢占
# 不设置则保持向后兼容（任何人可初始化）
# SETUP_TOKEN=your-random-secret-token

# ---- Redis 连接 (AI 摘要/知识库功能必填) ----
# AI 审核、NSFW 检测不需要 Redis
# 知识库功能需要 Redis Stack (含 RediSearch 模块)
REDIS_URL=redis://localhost:6379

# ---- 时区 (可选) ----
TZ=Asia/Shanghai

# ===========================================
# 注意：云函数部署不要使用 SQLite！
# 云函数的文件系统是临时的，重启后数据会丢失。
# 强列建议使用 MongoDB Atlas 或 Turso。
# ===========================================
